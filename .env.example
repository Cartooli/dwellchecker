NEXT_PUBLIC_APP_URL=http://localhost:3000
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Pooled connection (e.g. Neon pooler). Required for Prisma Client at runtime.
DATABASE_URL=
# Non-pooled URL for migrations and introspection. If you only have one Postgres URL locally,
# set this to the same value as DATABASE_URL (see README / Neon dashboard).
POSTGRES_URL_NON_POOLING=
# Legacy name — not read by prisma/schema.prisma (use POSTGRES_URL_NON_POOLING).
DIRECT_URL=
BLOB_READ_WRITE_TOKEN=
UPLOAD_MAX_BYTES=25000000
INTERNAL_JOB_SECRET=change-me-min-16-chars
CRON_SHARED_SECRET=change-me-min-16-chars
LOG_LEVEL=info
